# Ontario Tax Estimation Portal — environment template
# Copy to .env and fill in values as needed.

# Optional: enables LLM-enhanced AI insights. Without this, heuristic AI still works.
OPENAI_API_KEY=

# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# App display name (used in PDFs and UI chrome)
APP_OWNER_NAME=Your Name
